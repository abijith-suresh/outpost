{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "module": "node18",
    "moduleResolution": "node16",
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true,
    "strict": true,
    "target": "es2022",
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts"]
}
